#include <Wire.h>

#define I2C_ADDR 8

// same struct as Mega
struct DataPacket {
  float lat;
  float lon;
  uint16_t distance;
  uint8_t angle;
};

DataPacket data;

void setup() {
  Serial.begin(115200);
  Wire.begin(I2C_ADDR);
  Wire.onReceive(receiveEvent);

  Serial.println("UNO READY - WAITING FOR DATA");
}

void loop() {
  // nothing needed here
}

void receiveEvent(int bytes) {
  Serial.print("Received bytes: ");
  Serial.println(bytes);

  // -------- RAW VIEW (always works) --------
  Serial.print("Raw: ");
  while (Wire.available()) {
    byte b = Wire.read();
    Serial.print(b);
    Serial.print(" ");
  }
  Serial.println();

  // -------- TRY TO INTERPRET AS STRUCT --------
  if (bytes == sizeof(DataPacket)) {
    Wire.readBytes((char*)&data, sizeof(data));

    Serial.println("Parsed Data:");
    Serial.print("Lat: "); Serial.println(data.lat, 6);
    Serial.print("Lon: "); Serial.println(data.lon, 6);
    Serial.print("Distance: "); Serial.println(data.distance);
    Serial.print("Angle: "); Serial.println(data.angle);
    Serial.println("------");
  } else {
    Serial.println("Size mismatch (not struct)");
  }
}
