// -------------------- LIDAR READ --------------------
uint16_t readDistance()
{
Wire.beginTransmission(LIDAR_ADDR);
Wire.write(0x00);
Wire.endTransmission();

Wire.requestFrom(LIDAR_ADDR, 2);

if (Wire.available() >= 2) {
uint16_t dist = Wire.read();
dist |= Wire.read() << 8;
return dist;
}
return 0xFFFF;
}

void updatePosition()
{
  unsigned long now = millis();
  float dt = (now - lastMoveTime) / 1000.0; // seconds
  lastMoveTime = now;

  // Distance moved in this timestep
  float distance = speed_cm_per_sec * dt;

  // Convert heading to radians
  float rad = heading_imu * PI / 180.0;

  // Update grid position
  currentX += cos(rad) * distance;
  currentY += sin(rad) * distance;
}

