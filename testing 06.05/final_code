void computeHeading(float x, float y, float tx, float ty)
{
  float dx = tx - x;
  float dy = ty - y;

  // FIXED: Changed dist_to_targ to distance_to_target to match global variable
  distance_to_target = sqrt (dx * dx + dy * dy);

  float angle_rad = atan2(dy, dx);

  // FIXED: Changed angle_radians to angle_rad
  heading = angle_rad * 180.0 / PI;

  if (heading < 0 ) {
  heading += 360.0;
  }
}

