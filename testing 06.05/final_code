    if (millis() - lastMove >= 50) {
    lastMove = millis();
  
    miniServo.write(pos);
    pos += dir;
  
    if (pos >= 180 || pos <= 0) dir *= -1;
  
    waypoint target = path[current_waypoint];
  
    distance_to_target = sqrt(
      pow(target.x - currentX, 2) +
      pow(target.y - currentY, 2)
    );
  
    uint16_t dist = readDistance();
    if (dist < 20) {
    if (pos < 90) {
    current_state = OBSTACLE_LEFT;
    }
    else {
    current_state = OBSTACLE_RIGHT;
