    // The birds-eye distance it took for the hovercraft to veer then get back on track is deducted
    distance_to_target = distance_to_target - veer_distance;
  
    if (distance_to_target > 5) {
    current_state = HEADING;
    }
    else {
    current_state = REACHED;
    current_waypoint++;
    }
    break;
  
  case REACHED:
    ESC1.writeMicroseconds(prop_stop);
    if (current_waypoint >= num_waypoints){
    // Add finish logic here
    }
    break; // <-- FIXED: Added missing break
    }

