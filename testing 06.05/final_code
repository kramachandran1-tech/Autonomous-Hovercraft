//-----------------PID------------------
float computePID(float error)
{
  unsigned long now = millis();

  // FIXED: Changed capital 'Now' to lowercase 'now'
  float dt = (now - lastTime) / 1000.0;

  if (dt <= 0) dt = 0.01;

  lastTime = now;

  integral += error * dt;
  float derivative = (error - previousError) / dt;

  float output = Kp * error + Ki * integral + Kd * derivative;

  previousError = error;

  return output;
}

// -----------------KALMAN---------------
float updateKalman(float measurement)
{
  kUncertainity += processNoise;

  float K = kUncertainity / (kUncertainity + measurementNoise);

  kAngle = kAngle + K * (measurement - kAngle);
  kUncertainity = (1 - K) * kUncertainity;

  return kAngle;
}

// FIXED: Added missing placeholder function so your code compiles
void acheiveDirection(float current_heading, float target_heading) {

  float error = target_heading - current_heading;

  if (error > 180) error -= 360;
  if (error < -180) error += 360;

  float correction = computePID(error);
  correction = constrain(correction, -40, 40);

  int base = 90;
  int output = base + correction;

  rudder1.write(output);
  rudder2.write(output);
}

//----------------------IMU SENSORS-------------------
void readMPU() {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x3B);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU_ADDR, 14, true);

  if (Wire.available() == 14) {
    ax = Wire.read() << 8 | Wire.read();
    ay = Wire.read() << 8 | Wire.read();
    az = Wire.read() << 8 | Wire.read();

    Wire.read(); Wire.read(); // temp

    gx = Wire.read() << 8 | Wire.read();
    gy = Wire.read() << 8 | Wire.read();
    gz = Wire.read() << 8 | Wire.read();
  }
}


void updateIMU()
{
  unsigned long now = millis();
  float dt = (now - imu_lastTime) / 1000.0;
  imu_lastTime = now;

  if (dt <= 0) dt = 0.01;

  readMPU();

  // Convert gyro Z to deg/sec
  float gyroZ_rate = (gz - gyroZ_offset) / 131.0;
  // Integrate to get heading
  heading_imu += gyroZ_rate * dt;

  // Wrap angle
  if (heading_imu >= 360) heading_imu -= 360;
  if (heading_imu < 0) heading_imu += 360;
}

void calibrateGyro() {
  long sum = 0;
  int samples = 500;

  for (int i = 0; i < samples; i++) {
    readMPU();
    sum += gz;
    delay(2);
  }

  gyroZ_offset = sum / (float)samples;
}

