#include <Servo.h>
#include <Wire.h>

#define MPU_ADDR 0x68

Servo rudder1, rudder2;
Servo ESC1, ESC2;

// Waypoint
struct waypoint {
  float x;
  float y;
};

waypoint target = {50, 300};

// Position
float currentX = 0;
float currentY = 0;

// Heading
float heading_imu = 0;
float filteredHeading = 0;
float target_heading = 0;

// IMU
int16_t gz;
float gyroZ_offset = 0;
unsigned long imu_lastTime = 0;

// PID
float Kp = 1.2, Ki = 0.0, Kd = 1.0;
float integral = 0, previousError = 0;
unsigned long lastTime = 0;

// Kalman
float kAngle = 0, kUncertainty = 2;
float processNoise = 0.05, measurementNoise = 6;

// Movement
const int lift_speed = 1100;
const int prop_speed = 1200;
const int prop_stop = 1000;

float speed_cm_per_sec = 20.0;
unsigned long lastMoveTime = 0;

// =================================================
void setup() {

  ESC1.attach(8, 1000, 2000);
  ESC2.attach(10, 1000, 2000);

  ESC1.writeMicroseconds(1000);
  ESC2.writeMicroseconds(1000);
  delay(2000);

  rudder1.attach(4);
  rudder2.attach(5);

  Serial.begin(115200);
  Wire.begin();

  // Wake MPU
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x6B);
  Wire.write(0);
  Wire.endTransmission(true);

  calibrateGyro();

  imu_lastTime = millis();
  lastTime = millis();
  lastMoveTime = millis();
}

// =================================================
void loop() {

  updateIMU();
  filteredHeading = updateKalman(heading_imu);

  // Always keep lift ON
  ESC2.writeMicroseconds(lift_speed);

  // Compute navigation
  target_heading = computeHeading(currentX, currentY, target.x, target.y);
  float distance = computeDistance(currentX, currentY, target.x, target.y);

  // Steering
  acheiveDirection(filteredHeading, target_heading);

  // Movement
  if (distance > 10) {
    ESC1.writeMicroseconds(prop_speed);
  } else {
    ESC1.writeMicroseconds(prop_stop);
  }

  updatePosition();

  // Debug
  Serial.print("Dist: ");
  Serial.print(distance);
  Serial.print(" Heading: ");
  Serial.println(filteredHeading);
}

// =================================================
// NAVIGATION
// =================================================
float computeDistance(float x, float y, float tx, float ty) {
  float dx = tx - x;
  float dy = ty - y;
  return sqrt(dx * dx + dy * dy);
}

float computeHeading(float x, float y, float tx, float ty) {
  float dx = tx - x;
  float dy = ty - y;

  float angle = atan2(dy, dx) * 180.0 / PI;
  if (angle < 0) angle += 360;

  return angle;
}

// =================================================
// CONTROL
// =================================================
void acheiveDirection(float current, float target) {

  float error = target - current;

  if (error > 180) error -= 360;
  if (error < -180) error += 360;

  float output = computePID(error);
  output = constrain(output, -45, 45);

  int servoAngle = constrain(90 + output, 45, 135);

  rudder1.write(servoAngle);
  rudder2.write(servoAngle);
}

float computePID(float error) {

  unsigned long now = millis();
  float dt = (now - lastTime) / 1000.0;
  if (dt <= 0) dt = 0.01;

  lastTime = now;

  integral += error * dt;
  float derivative = (error - previousError) / dt;

  previousError = error;

  return Kp * error + Ki * integral + Kd * derivative;
}

// =================================================
// KALMAN
// =================================================
float updateKalman(float measurement) {
  kUncertainty += processNoise;
  float K = kUncertainty / (kUncertainty + measurementNoise);
  kAngle = kAngle + K * (measurement - kAngle);
  kUncertainty = (1 - K) * kUncertainty;
  return kAngle;
}

// =================================================
// IMU
// =================================================
void readMPU() {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x47);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU_ADDR, 2, true);

  if (Wire.available() == 2) {
    gz = Wire.read() << 8 | Wire.read();
  }
}

void updateIMU() {
  unsigned long now = millis();
  float dt = (now - imu_lastTime) / 1000.0;
  imu_lastTime = now;

  readMPU();

  float rate = (gz - gyroZ_offset) / 131.0;
  heading_imu += rate * dt;

  if (heading_imu >= 360) heading_imu -= 360;
  if (heading_imu < 0) heading_imu += 360;
}

void calibrateGyro() {
  long sum = 0;
  for (int i = 0; i < 500; i++) {
    readMPU();
    sum += gz;
    delay(2);
  }
  gyroZ_offset = sum / 500.0;
}

// =================================================
// POSITION
// =================================================
void updatePosition() {

  unsigned long now = millis();
  float dt = (now - lastMoveTime) / 1000.0;
  lastMoveTime = now;

  float distance = speed_cm_per_sec * dt;

  float rad = filteredHeading * PI / 180.0;

  currentX += cos(rad) * distance;
  currentY += sin(rad) * distance;
}
