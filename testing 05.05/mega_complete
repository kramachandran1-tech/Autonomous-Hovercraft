void readMagnetometer(float &heading_deg)
{
  int16_t mx, my, mz;

  Wire.beginTransmission(HMC5883L_ADDR);
  Wire.write(0x03); // Data register
  Wire.endTransmission();

  Wire.requestFrom(HMC5883L_ADDR, 6);

  if (Wire.available() == 6) {
    mx = Wire.read() << 8 | Wire.read();
    mz = Wire.read() << 8 | Wire.read();
    my = Wire.read() << 8 | Wire.read();

    float heading = atan2((float)my, (float)mx);

    // Convert to degrees
    heading_deg = heading * 180.0 / PI;

    if (heading_deg < 0)
      heading_deg += 360.0;
  }
}

//-----------------PID------------------
float computePID(float error)
{
  unsigned long now = millis();

  // FIXED: Changed capital 'Now' to lowercase 'now'
  float dt = (now - lastTime) / 1000.0;

  if (dt <= 0) dt = 0.01;

  lastTime = now;

  integral += error * dt;
  float derivative = (error - previousError) / dt;

  float output = Kp * error + Ki * integral + Kd * derivative;

  previousError = error;

  return output;
}

// -----------------KALMAN---------------
float updateKalman(float measurement)
{
  kUncertainity += processNoise;

  float K = kUncertainity / (kUncertainity + measurementNoise);

  kAngle = kAngle + K * (measurement - kAngle);
  kUncertainity = (1 - K) * kUncertainity;

  return kAngle;
}

// FIXED: Added missing placeholder function so your code compiles
void acheiveDirection(float current_heading, float target_heading) {

  float error = target_heading - current_heading;

  if (error > 180) error -= 360;
  if (error < -180) error += 360;

  float correction = computePID(error);

  int base = 90;
  rudder1.write(base + correction);
  rudder2.write(base + correction);

}

//----------------------IMU SENSORS-------------------
float readGyroZ()
{
  int16_t gz;

  Wire.beginTransmission(ITG3205_ADDR);
  Wire.write(0x1D); // Z-axis high byte
  Wire.endTransmission();

  Wire.requestFrom(ITG3205_ADDR, 2);

  if (Wire.available() == 2) {
    gz = Wire.read() << 8 | Wire.read();

    // Sensitivity: 14.375 LSB per deg/sec
    float rate = gz / 14.375;

    return rate;
  }

  return 0;
}

void updateIMU()
{
  unsigned long now = millis();
  float dt = (now - imu_lastTime) / 1000.0;
  imu_lastTime = now;

  if (dt <= 0) dt = 0.01;

  // Read sensors
  float mag_heading;
  readMagnetometer(mag_heading);

  float gyro_rate = readGyroZ();

  // Predict (gyro)
  heading_imu += gyro_rate * dt;

  if (heading_imu >= 360) heading_imu -= 360;
  if (heading_imu < 0) heading_imu += 360;

  // Correct (Kalman)
  float corrected = updateKalman(mag_heading);

  // Blend (important)
  heading_imu = 0.98 * heading_imu + 0.02 * corrected;
}

