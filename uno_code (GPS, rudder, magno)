);

float smoothHeading = updateKalman(heading);

  float error = targetBearing - smoothHeading;

  // Normalize error
  if (error > 180) error -= 360;
  if (error < -180) error += 360;


  float pidOutput = computePID(error);

  int servoAngle = 90 + pidOutput;
  servoAngle = constrain(servoAngle, 60, 120);

  int baseSpeed = 180;
  int speed = baseSpeed - abs(pidOutput) * 0.8;


