}


double convertToDecimal(char* raw, char* direction) {
  double val = atof(raw);

  int degrees = (int)(val / 100);
  double minutes = val - (degrees * 100);

  double decimal = degrees + (minutes / 60.0);

  if (direction[0] == 'S' || direction[0] == 'W') {
    decimal *= -1;
  }

  return decimal;
}

