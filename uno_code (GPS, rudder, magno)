#include <Servo.h>
#include <Wire.h>
#include <SoftwareSerial.h>

SoftwareSerial HC12(2, 3); 

unsigned long lastTransmit = 0;
const unsigned long transmitInterval = 200; // ms

Servo rudder;

#define SERVO_PIN 9
#define MOTOR_PIN 10

#define I2C_ADDRESS 8

/* TARGET */
double targetLat = 53.3811;
double targetLon = -1.4701;

/* CURRENT POSITION (updated from Mega) */
double currentLat = 0;
double currentLon = 0;

float heading = 0;

float lidarAngle = 90;
float lidarDistance = 200;

/* I2C buffer */
char i2cBuffer[32];
volatile bool newData = false;

/* PID */
float Kp = 1.2;
float Ki = 0.0;
float Kd = 0.4;

float integral = 0;
float previousError = 0;
unsigned long lastTime = 0;

/* Kalman */
float kAngle = 0;
float kUncertainty = 2;
float processNoise = 0.05;
float measurementNoise = 2;

// -------------------- SETUP --------------------
void setup() {

  Serial.begin(115200);
  HC12.begin(9600);

  Wire.onReceive(receiveEvent);

  rudder.attach(SERVO_PIN);
  pinMode(MOTOR_PIN, OUTPUT);

  Wire.begin(); // for compass

  lastTime = millis();

  Serial.println("UNO Ready (I2C Slave)");
}

// -------------------- LOOP --------------------
void loop() {

  /* ---- RECEIVE GPS FROM MEGA ---- */
if (newData) {
  newData = false;

  char temp[32];
  strcpy(temp, i2cBuffer);

  parseIncomingData(temp);
}

  /* ---- NAVIGATION ---- */
  double distanceToTarget = distanceBetween(
    currentLat, currentLon,
    targetLat, targetLon
  );

  double targetBearing = courseTo(
    currentLat, currentLon,
    targetLat, targetLon
  );

  float smoothHeading = updateKalman(heading);

  float error = targetBearing - smoothHeading;

  if (error > 180) error -= 360;
  if (error < -180) error += 360;

  float pidOutput = computePID(error);

  int servoAngle = 90 + pidOutput;
  servoAngle = constrain(servoAngle, 60, 120);

  int baseSpeed = 180;
  int speed = baseSpeed - abs(pidOutput) * 0.8;

 int distanceAhead = lidarDistance;

  if (distanceAhead < 100) {
    servoAngle += 30;
    speed = 120;
  }

  speed = constrain(speed, 100, 255);

  rudder.write(servoAngle);
  analogWrite(MOTOR_PIN, speed);

  if (distanceToTarget < 3) {
    analogWrite(MOTOR_PIN, 0);
  }


if (millis() - lastTransmit >= transmitInterval) {
  lastTransmit = millis();

  // Only send if we have valid data
  if (currentLat != 0 && currentLon != 0) {
    sendGPS_HC12();
  
}


// -------------------- I2C RECEIVE --------------------
void receiveEvent(int bytes) {
  int i = 0;

  while (Wire.available() && i < sizeof(i2cBuffer) - 1) {
    i2cBuffer[i++] = Wire.read();
  }

  i2cBuffer[i] = '\0';
  newData = true;
}


// -------------------- PARSE I2C GPS --------------------
void parseIncomingData(char* data) {
  if (data[0] == 'G') {
    parseGPS(data);
  } 
  else if (data[0] == 'L') {
    parseLidar(data);
  }
  else if (data[0] == 'H') {
    parseHeading(data);
  }
}

void parseGPS(char* data) {
  strtok(data, ","); // skip 'G'

  char* latStr = strtok(NULL, ",");
  char* lonStr = strtok(NULL, ",");

  if (latStr && lonStr) {
    currentLat = atof(latStr);
    currentLon = atof(lonStr);

    Serial.print("GPS -> ");
    Serial.print(currentLat, 6);
    Serial.print(", ");
    Serial.println(currentLon, 6);
  }
}


void parseLidar(char* data) {
  strtok(data, ","); // skip 'L'

  char* angleStr = strtok(NULL, ",");
  char* distStr  = strtok(NULL, ",");

  if (angleStr && distStr) {
    lidarAngle = atof(angleStr);
    lidarDistance = atof(distStr);

    Serial.print("LIDAR -> Angle: ");
    Serial.print(lidarAngle);
    Serial.print(" Dist: ");
    Serial.println(lidarDistance);
  }
}

void parseHeading(char* data) {
  strtok(data, ","); // skip 'H'

  char* headingStr = strtok(NULL, ",");

  if (headingStr) {
    heading = atof(headingStr);

    Serial.print("HEADING -> ");
    Serial.println(heading);
  }
}

void sendGPS_HC12() {
  HC12.print(currentLat, 6);
  HC12.print(",");
  HC12.print(currentLon, 6);
  HC12.print("\n");
}


// -------------------- PID --------------------
float computePID(float error) {
  unsigned long now = millis();
  float dt = (now - lastTime) / 1000.0;

  if (dt <= 0) dt = 0.01;

  lastTime = now;

  integral += error * dt;
  float derivative = (error - previousError) / dt;

  float output = Kp * error + Ki * integral + Kd * derivative;

  previousError = error;

  return output;
}

// -------------------- KALMAN --------------------
float updateKalman(float measurement) {
  kUncertainty += processNoise;

  float K = kUncertainty / (kUncertainty + measurementNoise);

  kAngle = kAngle + K * (measurement - kAngle);
  kUncertainty = (1 - K) * kUncertainty;

  return kAngle;
}



// -------------------- NAV MATH --------------------
double distanceBetween(double lat1, double lon1, double lat2, double lon2) {
  const double R = 6371000;

  double dLat = radians(lat2 - lat1);
  double dLon = radians(lon2 - lon1);

  lat1 = radians(lat1);
  lat2 = radians(lat2);

  double a = sin(dLat/2) * sin(dLat/2) +
             sin(dLon/2) * sin(dLon/2) * cos(lat1) * cos(lat2);

  double c = 2 * atan2(sqrt(a), sqrt(1 - a));

  return R * c;
}

double courseTo(double lat1, double lon1, double lat2, double lon2) {
  lat1 = radians(lat1);
  lat2 = radians(lat2);
  double dLon = radians(lon2 - lon1);

  double y = sin(dLon) * cos(lat2);
  double x = cos(lat1)*sin(lat2) -
             sin(lat1)*cos(lat2)*cos(dLon);

  double bearing = atan2(y, x);

  bearing = degrees(bearing);
  if (bearing < 0) bearing += 360;

  return bearing;
}
